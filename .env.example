APP_NAME=WhatsApp SaaS Platform
APP_ENV=development
APP_DEBUG=true
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/whatsapp_saas
LOG_LEVEL=INFO
STRICT_CONFIG_VALIDATION=false
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DEFAULT_HISTORY_LIMIT=12
MAX_CONTEXT_CHARACTERS=8000
MAX_RESPONSE_CHARACTERS=900
DEFAULT_EMPTY_MESSAGE_RESPONSE=Olá! Não consegui identificar sua mensagem. Pode enviar novamente com mais detalhes?
DEFAULT_GREETING_MESSAGE=Olá! Sou o assistente virtual da {company_name}. Como posso ajudar?
DEFAULT_AGENT_STYLE=profissional, educado e objetivo

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_COMPLETION_TOKENS=300
OPENAI_DEFAULT_TEMPERATURE=0.3
WHATSAPP_TIMEOUT_SECONDS=15

EXTERNAL_RETRY_ATTEMPTS=3
EXTERNAL_RETRY_BACKOFF_SECONDS=0.8
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_QUEUE_MESSAGES=messages
IDEMPOTENCY_TTL_SECONDS=3600

BOOTSTRAP_COMPANY_NAME=
BOOTSTRAP_COMPANY_SLUG=
BOOTSTRAP_DEV_NAME=
BOOTSTRAP_DEV_EMAIL=
BOOTSTRAP_DEV_PASSWORD=
